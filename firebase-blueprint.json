{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Resume analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "role": { "type": "string" },
        "score": { "type": "number" },
        "skillsFound": { "type": "array", "items": { "type": "string" } },
        "missingSkills": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "string" },
        "recommendedRoles": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "role", "score", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Resume analysis history"
    }
  }
}
